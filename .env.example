# Copy to .env:  cp .env.example .env

PORT=8001
HOST=0.0.0.0

MONGODB_URI=mongodb://localhost:27017
DB_NAME=organistation_auth

# Must match gateway JWT_SECRET exactly
JWT_SECRET=change-this-to-a-strong-shared-secret
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Downstream services for cascade delete on user removal
HR_SERVICE_URL=http://hr:8002
PROJECT_SERVICE_URL=http://projects:8003
FINANCE_SERVICE_URL=http://finance:8004
INTERNAL_SERVICE_SECRET=organistation_internal_secret

# Docker: MONGODB_URI=mongodb://mongo:27017
